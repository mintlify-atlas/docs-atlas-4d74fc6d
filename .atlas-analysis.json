  "keyFeatures": [
    "Pterodactyl panel API client with support for files, backups, databases, schedules, and startup variables",
    "GenericServer class wrapping power control, resource monitoring, and file management",
    "MinecraftServer class with HungerBridge integration for TPS, player counts, and console commands",
    "BridgeClient for the HungerBridge v2 API (ping, info, TPS, players, run commands, log)",
    "loadConfig utility for dataclass-backed YAML configuration with fallbacks",
    "MessageRouter for multi-destination logging (terminal, Minecraft broadcast, file) with color maps",
    "Validator for config schema validation with fatal, type-mismatch, fallback, and recommended error levels",
    "Snapshot for instant or time-averaged server resource metrics",
    "Scheduling helpers: snapSchedule, runCountdownEvents, waitForOnline, waitForOffline"
  ],
  "publicApiSurface": [
    "Panel(name, url, api_key)",
    "Panel.ping() -> bool",
    "Panel.validateAPI() -> bool",
    "Panel.schedules / .files / .backups / .databases / .startup / .commands",
    "GenericServer(name, panel, server_id)",
    "GenericServer.start() / .stop() / .restart() / .kill()",
    "GenericServer.getStatus() -> str",
    "GenericServer.isOnline() / .isOffline() -> bool",
    "GenericServer.getRAM() / .getCPU() / .getDisk() / .getNetworkIn() / .getNetworkOut()",
    "GenericServer.getUptime(formatted) -> int | str",
    "GenericServer.refresh() -> dict",
    "GenericServer.listFiles() / .uploadFile() / .downloadFile() / .deleteFiles() / .renameFiles() / .copyFiles() / .moveFiles()",
    "GenericServer.createFolder() / .compress() / .decompress()",
    "GenericServer.listBackups() / .createBackup() / .deleteBackup() / .downloadBackup()",
    "GenericServer.listDatabases() / .createDatabase() / .rotateDatabasePassword() / .deleteDatabase()",
    "GenericServer.getStartupVariables() / .updateStartupVariable()",
    "GenericServer.listSchedules() / .createSchedule() / .updateSchedule() / .deleteSchedule() / .runSchedule()",
    "GenericServer.enableSchedule() / .disableSchedule() / .getSchedule()",
    "MinecraftServer(name, panel, server_id, server_domain, server_port, bridge_port, bridge_token)",
    "MinecraftServer.getPlayers(mode) -> int | list",
    "MinecraftServer.getTPS(mode, rounding) -> float",
    "MinecraftServer.sendConsoleCommand(command, show_console, silent, normalize)",
    "MinecraftServer.sendBroadcast(message)",
    "BridgeClient(url, token)",
    "BridgeClient.runCommand(command, show_console, silent, normalize)",
    "BridgeClient.log(message, level)",
    "BridgeClient.getPing() -> int",
    "BridgeClient.getVersion() / .getPlatform() / .getMinecraftVersion() / .getStatus()",
    "BridgeClient.getTPS(mode) -> float",
    "BridgeClient.getPlayers(mode) -> int | list",
    "loadConfig(schema, runtime_path)",
    "MessageRouter(name, Servers, log_path, ...)",
    "MessageRouter.info() / .warn() / .error()",
    "MessageRouter.origin() / .destination() / .broadcast() / .filelog()",
    "Validator(msg_templates)",
    "Validator.run(*configs) -> str",
    "Validator.validate_key_types(obj, schema)",
    "Validator.check_field(obj, name)",
    "Snapshot(Server, rounding, duration, interval, drop_outliers, gb)",
    "snapSchedule(minimumMinutes, snapMinutes) -> dict",
    "runCountdownEvents(target_time, minute_callbacks, second_callbacks, tick_interval)",
    "waitForOnline(server, timeout, interval) -> bool",
    "waitForOffline(server, timeout, interval) -> bool",
    "secsUntil(target) -> int",
    "minsUntil(target) -> int",
    "clearTerminal()",
    "validateAll(panel, server) -> bool",
    "ValidationError / FatalError / TypeMismatchError / FallbackError / RecommendedError",
    "HungerLibError / InvalidLevelError / InvalidModeError / HungerBridgeError"
  ]
}
